# Copy this file to .env and fill in real values locally.
# NEVER commit the real .env file — it is already excluded via .gitignore.

# --- Database ---
DATABASE_URL=postgresql://app_user:CHANGE_ME@localhost:5432/icecream_platform

# --- JWT signing ---
# Local dev uses HS256 with a shared secret for simplicity. Production should
# switch to RS256 with a real keypair (see SECURITY_CHECKLIST.md).
JWT_SECRET=generate_a_long_random_string_for_local_dev
JWT_ALGORITHM=HS256

# --- MFA secret encryption (Fernet key) ---
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_CHANGE_ME

# --- OIDC Provider (Auth0 / Keycloak / Cognito) — for production, not local dev ---
OIDC_ISSUER_URL=https://your-tenant.auth0.com/
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME

# --- App ---
ENVIRONMENT=development

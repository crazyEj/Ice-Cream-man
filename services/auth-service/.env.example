# Copy this file to .env and fill in real values locally.
# NEVER commit the real .env file — it is already excluded via .gitignore.

# --- Database ---
DATABASE_URL=postgresql://app_user:CHANGE_ME@localhost:5432/icecream_platform

# --- JWT signing (use an RS256 keypair in production, not a shared secret) ---
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ALGORITHM=RS256

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_CHANGE_ME

# --- OIDC Provider (Auth0 / Keycloak / Cognito) ---
OIDC_ISSUER_URL=https://your-tenant.auth0.com/
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME

# --- App ---
ENVIRONMENT=development
